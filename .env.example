# Optional API keys for Muon research workflows.
# Copy to .env locally if needed. Never commit real secrets.

# Enables Firecrawl-style source capture when a Firecrawl connector/tool is unavailable.
FIRECRAWL_API_KEY=

# Helps avoid Semantic Scholar public API rate limits.
SEMANTIC_SCHOLAR_API_KEY=

# Required by OpenAlex for normal metadata searches.
OPENALEX_API_KEY=

# Optional metadata/retrieval providers used by PaperQA and research agents.
CROSSREF_API_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=
